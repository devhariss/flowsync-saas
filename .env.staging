# FlowSync — Staging environment config
# Copy to .env.local and fill in real values

NEXT_PUBLIC_APP_ENV=staging
NEXT_PUBLIC_APP_URL=https://staging.flowsync.io
NEXT_PUBLIC_APP_NAME=FlowSync

# Analytics (replace with real keys)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Stripe (test keys for staging)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://staging.flowsync.io
